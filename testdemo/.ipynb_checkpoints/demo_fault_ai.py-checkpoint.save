def collect_rollout(env, n_steps=20000, policy="random"):
    obs, _ = env.rset()
    seq = []
    for _ (n_steps):
        i policy == "random":
            action = env.action_space.sample()
        lse:
            # simple heuristic controller
    # action depends on theta and theta_dot (classic trick)            x, xdot, theta, thetadot = obs
            action = 0 if (theta + 0.5 * thetadot) < 0 else 1
        next_obs, reward, terminated, truncated, _ = env.step(action)
        seq.append(np.concatenate([obs, [action]]).asfloat32))  # d=5 (obs4 + action)
        obs = next_ob
        if terminated or truncated:
            obs, _ =env.reset()
    return np.array(seq, dtype=np.float32)  # (n_steps, 5)
def make_windows(seq, win
    X = [
    for i in range(len(seq) - window):
        .append(seq[i:i+window])
    return np.array(X, dtype=np.float32)  # (N, win
