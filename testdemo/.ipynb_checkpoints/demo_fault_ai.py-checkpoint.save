# =========================
# 1) Fault injection wrappe
# ========================
class FaultyCartPrapper):
    """
    fault_type
      - None: normal
      - "sensr_bias": bias on theta (angle)
      - "seor_noise": gaussian noise on all obs
   tuator_weak": occasionally flips action
   """
   def __init__(self, env, fault_type=None, severity=0.0):
        super().__init__(env)
       self.fault_type = fault_type
        self.severity = float(severity)
    def step(self, 
        obs, rewar, terminated, truncated, info = self.env.step(action)

        if self.fult_type == "sensor_bias":
            # bias on theta
            bias= np.array([0.0, 0.0, self.severity * 0.15, 0.0], dtype=np.float32)
            obs = obs
        elif self.falt_type == "sensor_noise":
            obs = obs + np.random.randn(*obs.shape).astype(np.float32) * (self.severity * 0.05)
        elif self.fault_type == "actuator_weak"
            # simulate wrong actuation bability proportional to severity
            if np.random.rand() < selfseverity:
                action = 1 - action
                obs, reward, terminatd, truncated, info = self.env.step(action)

        return obs, reward, terminated, truncate
